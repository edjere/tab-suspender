{
  "manifest_version": 3,
  "name": "Tab Suspender",
  "version": "1.1.0",
  "description": "Automatically suspend inactive tabs to free memory. Local build, no tracking, no network access.",
  "permissions": [
    "tabs",
    "alarms",
    "storage",
    "contextMenus",
    "scripting",
    "tabGroups"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "suspend-current": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Suspend the current tab"
    },
    "suspend-others": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Suspend other tabs in this window"
    },
    "toggle-whitelist": {
      "suggested_key": {
        "default": "Ctrl+Shift+W",
        "mac": "Command+Shift+W"
      },
      "description": "Toggle whitelist for current domain"
    }
  },
  "incognito": "spanning"
}
